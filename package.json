{
  "name": "kahuna",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter @kahuna/web",
    "dev:api": "turbo dev --filter @kahuna/api",
    "build": "turbo build",
    "start": "turbo start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "clean": "rm -rf apps/*/dist packages/*/dist apps/*/tsconfig.tsbuildinfo packages/*/tsconfig.tsbuildinfo node_modules/.cache .turbo",
    "db:generate": "pnpm --filter @kahuna/api db:generate",
    "db:seed": "pnpm --filter @kahuna/api db:seed",
    "db:migrate": "pnpm --filter @kahuna/api db:migrate",
    "db:push": "pnpm --filter @kahuna/api db:push",
    "db:studio": "pnpm --filter @kahuna/api db:studio",
    "db:reset": "pnpm --filter @kahuna/api db:reset",
    "test:init": "node packages/testing/dist/cli.js init",
    "test:create": "node packages/testing/dist/cli.js create",
    "test:submit": "node packages/testing/dist/cli.js submit"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "turbo": "^2.0.0",
    "typescript": "^5.9.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=18.0.0"
  }
}
