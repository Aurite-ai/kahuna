# ===========================================
# Database
# ===========================================
# SQLite database file (relative to apps/api/)
DATABASE_URL="file:./dev.db"

# ===========================================
# Server
# ===========================================
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ===========================================
# Logging
# ===========================================
# Options: fatal, error, warn, info, debug, trace, silent
LOG_LEVEL=info

# ===========================================
# Frontend (Vite)
# ===========================================
VITE_API_URL=http://localhost:3000

# ===========================================
# Authentication
# ===========================================
# Generate with: openssl rand -base64 48
SESSION_SECRET=your-64-character-secret-here-generate-with-openssl-rand-base64-48

# ===========================================
# AI Services (as needed)
# ===========================================
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
