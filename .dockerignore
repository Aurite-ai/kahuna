# Docker build context exclusions for Kahuna MCP server
#
# Docker builds from repo root using:
#   docker build -f apps/mcp/Dockerfile .
#
# This file must be at the repo root since that's the build context.

# =============================================================================
# Node.js dependencies (rebuilt in Docker)
# =============================================================================
node_modules/
**/node_modules/

# =============================================================================
# Build outputs (rebuilt in Docker)
# =============================================================================
dist/
**/dist/

# =============================================================================
# Development files
# =============================================================================
*.log
*.tgz
.env
.env.*
!.env.example

# =============================================================================
# Test files (not needed in image)
# =============================================================================
**/__tests__/
**/*.test.ts
**/*.spec.ts
**/vitest.config.ts
**/jest.config.*
coverage/

# =============================================================================
# Documentation (not needed in image)
# =============================================================================
docs/
*.md
!apps/mcp/README.md

# =============================================================================
# IDE and editor files
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~

# =============================================================================
# Git
# =============================================================================
.git/
.gitignore

# =============================================================================
# Python virtual environments (if any)
# =============================================================================
.venv/
venv/
__pycache__/

# =============================================================================
# Roo/Claude Code configuration
# =============================================================================
.roo/

# =============================================================================
# Local knowledge base (mounted as volume in production)
# =============================================================================
.kahuna/
