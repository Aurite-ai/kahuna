// =============================================================================
// Kahuna Prisma Schema
// =============================================================================
// Single schema file with logical ownership separation via comments.
// See docs/internal/tasks/infra-setup/design/foundational-infrastructure.md
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  // URL configured in prisma.config.ts (Prisma 7+)
}

// =============================================================================
// FOUNDATION TABLES - Owned by Infrastructure
// These tables handle authentication and user identity.
// The feedback loop references users.id but never touches these directly.
// =============================================================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // bcrypt hashed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  sessions Session[]
  projects Project[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// =============================================================================
// PROJECT - Bridge between Infrastructure and Feedback Loop
// Infrastructure owns the user relationship.
// The feedback loop owns everything else about projects.
// =============================================================================

model Project {
  id        String   @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Infrastructure relation (user ownership)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Loop relations
  contextFiles   ContextFile[]
  vckGenerations VckGeneration[]
  buildResults   BuildResult[]

  @@index([userId])
}

// =============================================================================
// FEEDBACK LOOP TABLES - Owned by the Feedback Loop
// These tables store the core business data for VCK generation and improvement.
// =============================================================================

model ContextFile {
  id         String   @id @default(cuid())
  projectId  String
  filename   String
  content    String
  category   String?  // business-info | technical-info | code
  confidence Float?   // 0-1 confidence score from categorization
  reasoning  String?  // Why this category was chosen
  metadata   String?  // JSON blob containing rich metadata (entities, tags, summary, etc.)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([category])
}

model VckGeneration {
  id        String   @id @default(cuid())
  projectId String
  framework String   @default("langgraph")
  copilot   String   @default("claude-code")
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model BuildResult {
  id              String   @id @default(cuid())
  projectId       String
  code            Json     // src/ files as Record<string, string>
  docs            Json     // docs/ files as Record<string, string>
  tests           Json     // tests/ files as Record<string, string>
  conversationLog String? // Optional conversation log from coding copilot
  createdAt       DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// =============================================================================
// TESTING TABLES - Owned by Testing Infrastructure
// These tables support VCK quality testing and evaluation.
// =============================================================================

model TestSession {
  id           String    @id @default(cuid())
  scenarioId   String
  testerName   String
  testerEmail  String?
  framework    String    @default("langgraph")
  copilot      String    @default("claude-code")
  status       String    @default("created") // created, in_progress, completed
  startedAt    DateTime  @default(now())
  completedAt  DateTime?

  // Relations
  evaluations TestEvaluation[]

  @@index([scenarioId])
  @@index([status])
}

model TestEvaluation {
  id            String   @id @default(cuid())
  testSessionId String
  score         Int?     // Optional numeric score
  notes         String?
  metrics       String? // JSON blob for structured evaluation data
  createdAt     DateTime @default(now())

  testSession TestSession @relation(fields: [testSessionId], references: [id], onDelete: Cascade)

  @@index([testSessionId])
}
