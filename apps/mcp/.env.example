# Database connection for local development
# Start PostgreSQL with: docker compose up -d (from repo root)

# Authentication
SESSION_SECRET="dev-secret-do-not-use-in-production-must-be-at-least-32-chars"

# Server
PORT=3000
NODE_ENV=development
KAHUNA_KNOWLEDGE_DIR=/path/to/your/local/kahuna/.kahuna-knowledge
LOG_LEVEL=info

ANTHROPIC_API_KEY=your-anthropic-api-key-here
KAHUNA_SESSION_TOKEN=kahuna-session-dev-1234567890abcdef