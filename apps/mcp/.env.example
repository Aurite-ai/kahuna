# Kahuna MCP Server Configuration

# =============================================================================
# REQUIRED SETTINGS
# =============================================================================

# Path to local knowledge base directory
KAHUNA_KNOWLEDGE_DIR=/path/to/your/local/kahuna/.kahuna-knowledge

# Anthropic API key (required for categorization and ask tool)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# =============================================================================
# MODEL CONFIGURATION (Optional)
# =============================================================================
# Override the default models used for different tasks.
# If not set, all tasks use: claude-sonnet-4-20250514
#
# Available models (non-deprecated):
#   - claude-opus-4-6        (Most capable, highest cost)
#   - claude-opus-4-5        (Most capable, highest cost)
#   - claude-sonnet-4-5      (Balanced performance/cost)
#   - claude-sonnet-4        (Balanced performance/cost)
#   - claude-sonnet-4-20250514 (Balanced - DEFAULT)
#   - claude-haiku-4-5       (Fast, economical)
#   - claude-3-5-haiku-20241022 (Fast, economical)
#   - claude-3-haiku-20240307 (Fastest, cheapest)

# Model for file categorization during kahuna_learn (fast, cheap recommended)
# KAHUNA_MODEL_CATEGORIZATION=claude-3-haiku-20240307

# Model for KB retrieval agent used by prepare_context tool
# KAHUNA_MODEL_RETRIEVAL=claude-sonnet-4-20250514

# Model for the ask tool's agentic Q&A loop (more capable recommended)
# KAHUNA_MODEL_ASK=claude-opus-4-6

# Model for contradiction checking during kahuna_learn
# KAHUNA_MODEL_CONTRADICTION=claude-sonnet-4-20250514

# Model for LLM-based secret verification (fast, cheap recommended)
# KAHUNA_MODEL_LLM_VERIFICATION=claude-3-haiku-20240307

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Perplexity integration for web search (disabled by default)
ENABLE_PERPLEXITY_INTEGRATION=false

# =============================================================================
# LOGGING
# =============================================================================

# Logging level (debug, info, warn, error)
LOG_LEVEL=info
