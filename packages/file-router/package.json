{
  "name": "@kahuna/file-router",
  "version": "0.0.1",
  "type": "module",
  "description": "File categorization and routing for Kahuna",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "npx tsx test-categorizer.ts",
    "test:quick": "npx tsx quick-test.ts",
    "test:interactive": "npx tsx test-categorizer.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "dotenv": "^16.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.3.3"
  }
}
