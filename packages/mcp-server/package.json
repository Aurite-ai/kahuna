{
  "name": "@kahuna/mcp-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "MCP server that wraps Kahuna tRPC API as MCP tools",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "kahuna-mcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@trpc/client": "^11.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0"
  }
}
